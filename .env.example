# RetriFlow runtime
RETRIFLOW_DATABASE_BACKEND=pg
RETRIFLOW_DATABASE_DSN=postgresql://retriflow:retriflow@127.0.0.1:5433/retriflow
RETRIFLOW_DATABASE_SCHEMA=public
RETRIFLOW_DB_PATH=backend/data/retriflow.db
RETRIFLOW_SEED_DEMO_CONTENT=false
RETRIFLOW_ALLOW_SQLITE_FALLBACK=false
RETRIFLOW_WORKFLOW_ADAPTER=auto
RETRIFLOW_VECTOR_STORE_TYPE=pg
RETRIFLOW_PGVECTOR_DSN=postgresql://retriflow:retriflow@127.0.0.1:5433/retriflow
RETRIFLOW_PGVECTOR_TABLE=retriflow_chunk_vectors

# Model selection
# Reference baseline comes from ragent/bootstrap/src/main/resources/application.yaml
RETRIFLOW_DEFAULT_CHAT_MODEL=qwen3-max
RETRIFLOW_DEEP_THINKING_MODEL=qwen3-max
RETRIFLOW_DEFAULT_EMBEDDING_MODEL=qwen-emb-8b
RETRIFLOW_DEFAULT_RERANK_MODEL=Qwen/Qwen3-Reranker-8B
RETRIFLOW_CHAT_PROVIDER=bailian
RETRIFLOW_REWRITE_PROVIDER=ollama
RETRIFLOW_ROUTE_PROVIDER=ollama
RETRIFLOW_MEMORY_SUMMARY_PROVIDER=ollama
RETRIFLOW_EMBEDDING_PROVIDER=siliconflow
RETRIFLOW_RERANK_PROVIDER=siliconflow
RETRIFLOW_RETRIEVAL_BM25_TOP_K=80
RETRIFLOW_RETRIEVAL_VECTOR_TOP_K=80
RETRIFLOW_RETRIEVAL_RRF_TOP_K=50
RETRIFLOW_RETRIEVAL_RERANK_TOP_K=10
RETRIFLOW_RETRIEVAL_FINAL_TOP_K=5

# Sample knowledge directory
RETRIFLOW_SAMPLE_KNOWLEDGE_DIR=backend/sample_data/knowledge
RETRIFLOW_STORAGE_BACKEND=s3
RETRIFLOW_STORAGE_LOCAL_DIR=backend/data/uploads
RETRIFLOW_S3_ENDPOINT=http://127.0.0.1:9000
RETRIFLOW_S3_ACCESS_KEY_ID=rustfsadmin
RETRIFLOW_S3_SECRET_ACCESS_KEY=rustfsadmin
RETRIFLOW_S3_REGION=us-east-1
RETRIFLOW_LLM_PROVIDER=auto
RETRIFLOW_LLM_API_KEY=
RETRIFLOW_LLM_BASE_URL=
RETRIFLOW_LLM_REQUEST_TIMEOUT_SECONDS=30
RETRIFLOW_OLLAMA_BASE_URL=http://127.0.0.1:11434/v1
RETRIFLOW_OLLAMA_CHAT_MODEL=qwen3:8b
RETRIFLOW_OLLAMA_EMBEDDING_MODEL=qwen3-embedding:8b
RETRIFLOW_TIKA_ENABLED=false
RETRIFLOW_TIKA_ENDPOINT=http://127.0.0.1:9998
RETRIFLOW_TIKA_REQUEST_TIMEOUT_SECONDS=60
RETRIFLOW_TIKA_OCR_ENABLED=false
RETRIFLOW_TIKA_OCR_SERVICE_ENDPOINT=http://127.0.0.1:9889
RETRIFLOW_TIKA_OCR_REQUEST_TIMEOUT_SECONDS=30
RETRIFLOW_MCP_REMOTE_ENABLED=false
RETRIFLOW_MCP_REMOTE_SERVERS_JSON=[]
RETRIFLOW_MCP_REMOTE_TIMEOUT_SECONDS=15
RETRIFLOW_MCP_EXECUTION_MODE=sequential
RETRIFLOW_MCP_MAX_TOOL_CANDIDATES=3
RETRIFLOW_MCP_FAIL_FAST=false
RETRIFLOW_MCP_PARALLEL_MAX_WORKERS=3
RETRIFLOW_CHAT_QUEUE_ENABLED=false
RETRIFLOW_CHAT_QUEUE_BACKEND=redis
RETRIFLOW_CHAT_QUEUE_REDIS_URL=redis://127.0.0.1:6379/0
RETRIFLOW_CHAT_QUEUE_REDIS_KEY_PREFIX=retriflow:chat
RETRIFLOW_CHAT_QUEUE_MAX_CONCURRENT=4
RETRIFLOW_CHAT_QUEUE_MAX_WAIT_SECONDS=30
RETRIFLOW_CHAT_QUEUE_LEASE_SECONDS=120
RETRIFLOW_CHAT_QUEUE_POLL_INTERVAL_MS=100
RETRIFLOW_STREAM_TASK_CANCEL_REDIS_URL=redis://127.0.0.1:6379/0
RETRIFLOW_STREAM_TASK_CANCEL_KEY_PREFIX=retriflow:stream:cancel
RETRIFLOW_STREAM_TASK_CANCEL_TTL_SECONDS=1800
RETRIFLOW_INTENT_TREE_CACHE_ENABLED=true
RETRIFLOW_INTENT_TREE_CACHE_REDIS_URL=redis://127.0.0.1:6379/0
RETRIFLOW_INTENT_TREE_CACHE_KEY=retriflow:intent:tree
RETRIFLOW_INTENT_TREE_CACHE_TTL_DAYS=7
RETRIFLOW_QUERY_TERM_MAPPING_CACHE_ENABLED=false
RETRIFLOW_QUERY_TERM_MAPPING_CACHE_REDIS_URL=redis://127.0.0.1:6379/0
RETRIFLOW_QUERY_TERM_MAPPING_CACHE_KEY=retriflow:query-term:mappings
RETRIFLOW_QUERY_TERM_MAPPING_CACHE_TTL_DAYS=7
RETRIFLOW_MEMORY_HISTORY_KEEP_TURNS=8
RETRIFLOW_MEMORY_SUMMARY_ENABLED=true
RETRIFLOW_MEMORY_SUMMARY_START_TURNS=9
RETRIFLOW_MEMORY_SUMMARY_MAX_CHARS=240
RETRIFLOW_MEMORY_SHORT_TTL_DAYS=30
RETRIFLOW_MEMORY_MID_ENABLED=false
RETRIFLOW_MEMORY_MID_MAX_ITEMS=8
RETRIFLOW_MEMORY_LONG_ENABLED=false
RETRIFLOW_MEMORY_LONG_MAX_ITEMS=8


###############################################################
