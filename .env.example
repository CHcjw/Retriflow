# RetriFlow runtime
RETRIFLOW_DATABASE_BACKEND=pg
RETRIFLOW_DATABASE_DSN=postgresql://retriflow:retriflow@127.0.0.1:5433/retriflow
RETRIFLOW_DATABASE_SCHEMA=public
RETRIFLOW_DB_PATH=backend/data/retriflow.db
RETRIFLOW_WORKFLOW_ADAPTER=auto
RETRIFLOW_VECTOR_STORE_TYPE=pg
RETRIFLOW_PGVECTOR_DSN=postgresql://retriflow:retriflow@127.0.0.1:5433/retriflow
RETRIFLOW_PGVECTOR_TABLE=retriflow_chunk_vectors

# Model selection
# Reference baseline comes from ragent/bootstrap/src/main/resources/application.yaml
RETRIFLOW_DEFAULT_CHAT_MODEL=qwen3-max
RETRIFLOW_DEEP_THINKING_MODEL=qwen3-max
RETRIFLOW_DEFAULT_EMBEDDING_MODEL=qwen-emb-8b
RETRIFLOW_DEFAULT_RERANK_MODEL=qwen3-rerank

# Sample knowledge directory
RETRIFLOW_SAMPLE_KNOWLEDGE_DIR=backend/sample_data/knowledge
RETRIFLOW_LLM_PROVIDER=auto
RETRIFLOW_LLM_API_KEY=
RETRIFLOW_LLM_BASE_URL=
RETRIFLOW_LLM_REQUEST_TIMEOUT_SECONDS=30
RETRIFLOW_TIKA_ENABLED=false
RETRIFLOW_TIKA_ENDPOINT=http://127.0.0.1:9998
RETRIFLOW_TIKA_REQUEST_TIMEOUT_SECONDS=60
RETRIFLOW_TIKA_OCR_ENABLED=false
RETRIFLOW_TIKA_OCR_SERVICE_ENDPOINT=http://127.0.0.1:9889
RETRIFLOW_TIKA_OCR_REQUEST_TIMEOUT_SECONDS=30


###############################################################
# AI Provider API Keys
BAILIAN_API_KEY=
AIHUBMIX_API_KEY=
SILICONFLOW_API_KEY=
DEEPSEEK_API_KEY=
GROQ_API_KEY=
LANGSMITH_API_KEY=
LANGSMITH_TRACING=
LANGSMITH_PROJECT=

# Optional services
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
AIHUBMIX_BASE_URL=https://aihubmix.com/v1
SILICONFLOW_BASE_URL=https://api.siliconflow.cn/v1
DEEPSEEK_BASE_URL=https://api.deepseek.com
GROQ_BASE_URL=https://api.groq.com/openai/v1
TAVILY_API_KEY=
OSS_ACCESS_KEY_ID=
OSS_ACCESS_KEY_SECRET=
OSS_BUCKET=
PINECONE_API_KEY=
